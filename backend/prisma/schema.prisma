generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())

  name      String
  email     String   @unique
  password  String

  gender    String?
  dob       DateTime?
  job       String?
  status    String?
  avatarUrl String?

  journals          Journal[]
  screeningResults  ScreeningResult[]
  chatSessions      ChatSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resetToken       String?   
  resetTokenExpiry DateTime?
}

model Journal {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  mood    String
  content String
  tags    String[]
  
  // Analysis fields produced by AI service
  emotion String?
  sentiment_label String?
  sentiment_score Float?
  confidence Float?
  analysis Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScreeningResult {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Data statis dari User saat screening
  user_age    Int?
  user_gender String?

  // 10 Kolom Pertanyaan (semua skala 1-10)
  sleep_hours          Int
  screen_time          Int
  social_media         Int
  trauma_history       Int
  previously_diagnosed Int
  work_hours           Int
  work_stress          Int
  financial_stress     Int
  mood_swings          Int
  loneliness           Int

  // Hasil Akhir
  total_score    Int
  level          String
  recommendation String
  activity       String?

  createdAt DateTime @default(now())
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  role        String
  content     String
  safetyLevel String?
  source      String?
  createdAt   DateTime    @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

